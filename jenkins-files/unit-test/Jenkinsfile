pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {
    stage('Checkout') {
      steps {
        deleteDir()
        checkout scm

        sh 'mvn clean'
      }
    }

    stage('Unit Tests') {
      steps {
        // Continue even on failure so we can report the summary
        sh 'mvn test -Dmaven.test.failure.ignore=true'
      }
    }

    stage('Integration Tests') {
      steps {
        sh 'mvn verify -DskipUnitTests=true -Dmaven.test.failure.ignore=true'
      }
    }

    stage('Code Coverage') {
      steps {
        sh 'mvn jacoco:report'
      }
    }
  }

  post {
    always {
      junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
      
      script {
        // Check if the directory exists before grepping
        def reportDir = "target/surefire-reports"
        def dirExists = sh(script: "[ -d ${reportDir} ] && echo 'true' || echo 'false'", returnStdout: true).trim()

        def summary = "Build failed before tests could run."
        def state = "failure"

        if (dirExists == 'true') {
            def totalStr = sh(script: "grep -h 'testsuite' ${reportDir}/*.xml 2>/dev/null | sed -n 's/.*tests=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim()
            def failStr  = sh(script: "grep -h 'testsuite' ${reportDir}/*.xml 2>/dev/null | sed -n 's/.*failures=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim()
            def errStr   = sh(script: "grep -h 'testsuite' ${reportDir}/*.xml 2>/dev/null | sed -n 's/.*errors=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim()
            def skipStr  = sh(script: "grep -h 'testsuite' ${reportDir}/*.xml 2>/dev/null | sed -n 's/.*skipped=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim()

            int total = totalStr.toInteger()
            int failed = failStr.toInteger() + errStr.toInteger()
            int skipped = skipStr.toInteger()
            int passed = total - failed - skipped
            
            summary = "Tests: ${total} (Passed: ${passed}, Failed: ${failed}, Skipped: ${skipped})"
            
            // Only 'success' if the build passed AND there are no test failures
            if (currentBuild.result == 'SUCCESS' && failed == 0 && total > 0) {
                state = "success"
            }
        }

        withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
          sh """
          curl -s -H "Authorization: token \$TOKEN" \
          -H "Content-Type: application/json" \
          -X POST \
          https://api.github.com/repos/Alphonsa-senti/todo-chart/statuses/${GIT_COMMIT} \
          -d '{
            "state": "${state}",
            "context": "CI/CD / Unit Tests",
            "description": "${summary}",
            "target_url": "${BUILD_URL}"
          }'
          """
        }
      }
    }
  }
}