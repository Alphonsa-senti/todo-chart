def BRANCH = "${env.source_branch ?: 'main'}"

pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {

    stage('Checkout') {
      steps {
        // sh """git checkout ${BRANCH} && git pull origin ${BRANCH} --no-rebase"""
        checkout scm
      }
    }

    stage('Compile') {
      steps {
        dir('.') {
        sh 'mvn clean compile'
        }
      }
    }

    stage('Unit Tests') {
        steps {
            dir('.') {
                sh 'mvn test'
                sh 'echo "Current dir: $(pwd)"'
                sh 'ls -l target/'
                sh 'ls -l target/surefire-reports/'
            }
        }
        post {
            always {
                junit 'target/surefire-reports/*.xml'
            }
        }
    }

    stage('Integration Tests') {
        steps {
            dir('.') {
            sh 'mvn verify -DskipUnitTests=true'
            sh 'ls -l target/failsafe-reports/' 
            }
        }
        post {
            always {
            junit 'target/failsafe-reports/*.xml'
            }
        }
    }

    stage('Code Coverage') {
        steps {
            sh 'mvn clean test jacoco:report'
        }
        post {
            always {
            publishHTML([
                reportDir: 'target/site/jacoco',
                reportFiles: 'index.html',
                reportName: 'JaCoCo Coverage Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
            }
        }
    }

    stage('Package') {
      steps {
        sh 'mvn package -DskipTests'
      }
    }
  }

  post {
    success {
        githubNotify context: 'CI/CD', status: 'SUCCESS', description: 'Build passed', targetUrl: env.BUILD_URL
    }
    failure {
        githubNotify context: 'CI/CD', status: 'FAILURE', description: 'Build failed', targetUrl: env.BUILD_URL
    }
  }
}