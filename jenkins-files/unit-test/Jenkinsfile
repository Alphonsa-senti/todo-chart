pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Unit Tests') {
      steps {
        // Continue even on failure so we can report the summary
        sh 'mvn test -Dmaven.test.failure.ignore=true'
      }
    }

    stage('Integration Tests') {
      steps {
        sh 'mvn verify -DskipUnitTests=true -Dmaven.test.failure.ignore=true'
      }
    }

    stage('Code Coverage') {
      steps {
        sh 'mvn jacoco:report'
      }
    }
  }

  post {
    always {
      junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
      
      script {
        // Look for reports, but if the directory doesn't exist, this returns 0
        def totalStr = sh(script: "grep -h 'testsuite' target/surefire-reports/*.xml 2>/dev/null | sed -n 's/.*tests=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim()
        def failStr  = sh(script: "grep -h 'testsuite' target/surefire-reports/*.xml 2>/dev/null | sed -n 's/.*failures=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim()
        def errStr   = sh(script: "grep -h 'testsuite' target/surefire-reports/*.xml 2>/dev/null | sed -n 's/.*errors=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim()
        def skipStr  = sh(script: "grep -h 'testsuite' target/surefire-reports/*.xml 2>/dev/null | sed -n 's/.*skipped=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim()

        int total = totalStr.toInteger()
        int failed = failStr.toInteger() + errStr.toInteger()
        int skipped = skipStr.toInteger()
        int passed = total - failed - skipped
        
        def summary = "Tests: ${total} (Passed: ${passed}, Failed: ${failed}, Skipped: ${skipped})"
        
        // CRITICAL FIX: If the build result is not SUCCESS, the GitHub state should be 'failure'
        // even if the test parser (mistakenly) finds 0 failures.
        def state = (currentBuild.result == 'SUCCESS' && total > 0) ? "success" : "failure"
        
        // If the build failed before tests could even run (like your POM error)
        if (total == 0 && currentBuild.result != 'SUCCESS') {
            summary = "Build failed during compilation or setup."
        }

        withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
          sh """
          curl -s -H "Authorization: token \$TOKEN" \
          -H "Content-Type: application/json" \
          -X POST \
          https://api.github.com/repos/Alphonsa-senti/todo-chart/statuses/${GIT_COMMIT} \
          -d '{
            "state": "${state}",
            "context": "CI/CD / Unit Tests",
            "description": "${summary}",
            "target_url": "${BUILD_URL}"
          }'
          """
        }
      }
    }
  }
}