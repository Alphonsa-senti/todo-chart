def BRANCH = "${env.source_branch ?: 'main'}"

pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {

    stage('Checkout') {
      steps {
        // sh """git checkout ${BRANCH} && git pull origin ${BRANCH} --no-rebase"""
        checkout scm
      }
    }

    stage('Unit Tests') {
        steps {
            dir('.') {
                sh 'mvn test'
            }
        }
    }

    stage('Integration Tests') {
        steps {
            dir('.') {
            sh 'mvn verify -DskipUnitTests=true'
            }
        }
    }

    stage('Code Coverage') {
        steps {
            sh 'mvn clean test jacoco:report'
        }
    }
  }

  post {
    success {
        githubNotify(
            context: 'CI/CD',
            status: 'SUCCESS',
            description: 'Build passed',
            targetUrl: env.BUILD_URL,
            repo: 'Alphonsa-senti/todo-chart',
            credentialsId: 'basedynamics',
            sha: env.GIT_COMMIT
        )
    }
    failure {
        githubNotify(
            context: 'CI/CD',
            status: 'FAILURE',
            description: 'Build failed',
            targetUrl: env.BUILD_URL,
            repo: 'Alphonsa-senti/todo-chart',
            credentialsId: 'basedynamics',
            sha: env.GIT_COMMIT
        )
    }
  }
}