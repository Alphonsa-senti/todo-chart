def BRANCH = "${env.source_branch ?: 'main'}"

pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {

    stage('Checkout') {
      steps {
        script {
          def branchToBuild = env.source_branch ?: 'main'
          checkout([
            $class: 'GitSCM',
            branches: [[name: "*/${branchToBuild}"]],
            userRemoteConfigs: [[
              url: 'https://github.com/Alphonsa-senti/todo-chart.git',
              credentialsId: 'basedynamics'
            ]]
          ])
        }
      }
    }

    stage('Unit Tests') {
        steps {
            dir('.') {
                sh 'mvn test'
            }
        }
    }

    stage('Integration Tests') {
        steps {
            dir('.') {
            sh 'mvn verify -DskipUnitTests=true'
            }
        }
    }

    stage('Code Coverage') {
        steps {
            sh 'mvn clean test jacoco:report'
        }
    }

    stage('Debug Credentials') {
      steps {
        withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
          sh 'echo "Token loaded successfully"'
        }
      }
    }
  }


  post {
    success {
      githubNotify(
        context: 'CI/CD',
        status: 'SUCCESS',
        description: 'Build passed',
        targetUrl: env.BUILD_URL,
        repo: 'todo-chart',
        account: 'Alphonsa-senti',
        credentialsId: 'git-cred',
        sha: env.GIT_COMMIT
      )
    }
    failure {
      githubNotify(
        context: 'CI/CD',
        status: 'FAILURE',
        description: 'Build failed',
        targetUrl: env.BUILD_URL,
        repo: 'todo-chart',
        account: 'Alphonsa-senti',
        credentialsId: 'git-cred',
        sha: env.GIT_COMMIT
      )
    }
  }
}