post {
        always {
            // 1. Record results in Jenkins (this makes the 'Test Result' graph appear)
            junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
            
            script {
                // 2. Fetch results from the Jenkins JUnit plugin instead of manually parsing XML
                def testResult = currentBuild.rawBuild.getAction(hudson.tasks.test.AbstractTestResultAction.class)
                
                def state = "failure"
                def summary = "Build error or no tests found"
                
                if (testResult != null) {
                    def total = testResult.totalCount
                    def failed = testResult.failCount
                    def skipped = testResult.skipCount
                    def passed = total - failed - skipped
                    
                    summary = "Tests: ${total} (Passed: ${passed}, Failed: ${failed}, Skipped: ${skipped})"
                    
                    // Logic: Success only if there are tests and 0 failures
                    if (total > 0 && failed == 0) {
                        state = "success"
                    }
                } else if (currentBuild.result == 'SUCCESS') {
                    // Fallback if no tests were expected but build passed
                    state = "success"
                    summary = "Build completed successfully (no tests run)"
                }

                // 3. Update GitHub Status
                updateGithubStatus(state, "CI/CD / Unit Tests", summary)
            }
        }
    }
}

/**
 * Helper function to keep the pipeline clean
 */
def updateGithubStatus(String state, String context, String description) {
    withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
        sh """
            curl -s -H "Authorization: token ${TOKEN}" \
            -H "Content-Type: application/json" \
            -X POST \
            https://api.github.com/repos/Alphonsa-senti/todo-chart/statuses/${GIT_COMMIT} \
            -d '{
                "state": "${state}",
                "context": "${context}",
                "description": "${description}",
                "target_url": "${env.BUILD_URL}"
            }'
        """
    }
}