pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Unit Tests') {
      steps {
        // We use -Dmaven.test.failure.ignore=true so the pipeline continues 
        // to the report stage even if tests fail.
        sh 'mvn test -Dmaven.test.failure.ignore=true'
      }
    }

    stage('Integration Tests') {
      steps {
        sh 'mvn verify -DskipUnitTests=true -Dmaven.test.failure.ignore=true'
      }
    }

    stage('Code Coverage') {
      steps {
        sh 'mvn jacoco:report'
      }
    }
  }

  post {
    always {
      // Record results so Jenkins populates currentBuild.testCounts
      junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
      
      script {
        // Use sandbox-friendly currentBuild properties
        def total = currentBuild.totalTestCount ?: 0
        def failed = currentBuild.failTestCount ?: 0
        def skipped = currentBuild.skipTestCount ?: 0
        def passed = total - failed - skipped
        
        def summary = "Tests: ${total} (✔${passed}, ✘${failed}, ↷${skipped})"
        def state = (failed == 0 && total > 0) ? "success" : "failure"
        
        // If no tests were run at all, we should probably know
        if (total == 0) {
            summary = "No tests were executed."
            state = "failure" 
        }

        withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
          sh """
          curl -s -H "Authorization: token $TOKEN" \
          -H "Content-Type: application/json" \
          -X POST \
          https://api.github.com/repos/Alphonsa-senti/todo-chart/statuses/${GIT_COMMIT} \
          -d '{
            "state": "${state}",
            "context": "CI/CD / Tests",
            "description": "${summary}",
            "target_url": "${BUILD_URL}"
          }'
          """
        }
      }
    }
  }
}