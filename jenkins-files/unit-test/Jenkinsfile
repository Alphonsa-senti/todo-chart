pipeline {
    agent any

    tools {
        maven 'Maven 3.9.11'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'rm -rf target'
            }
        }

        stage('Unit Tests') {
            steps {
                sh 'mvn test -Dmaven.test.failure.ignore=true'
            }
        }
    }

    post {
        always {
            junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
            
            script {
                def reportDir = "target/surefire-reports"
                def state = "failure"
                def summary = "Build Failed"

                // Check if reports exist using shell (safe)
                def exists = sh(script: "[ -d ${reportDir} ] && ls ${reportDir}/*.xml >/dev/null 2>&1 && echo 'true' || echo 'false'", returnStdout: true).trim()

                if (exists == 'true') {
                    // Extract numbers using shell to avoid sandbox issues with Java File objects
                    def total = sh(script: "grep -h 'testsuite' ${reportDir}/*.xml | sed -n 's/.*tests=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim().toInteger()
                    def fails = sh(script: "grep -h 'testsuite' ${reportDir}/*.xml | sed -n 's/.*failures=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim().toInteger()
                    def errs  = sh(script: "grep -h 'testsuite' ${reportDir}/*.xml | sed -n 's/.*errors=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim().toInteger()
                    def skips = sh(script: "grep -h 'testsuite' ${reportDir}/*.xml | sed -n 's/.*skipped=\"\\([0-9]*\\)\".*/\\1/p' | awk '{s+=\$1} END {print (s==\"\"?0:s)}'", returnStdout: true).trim().toInteger()

                    def totalFailed = fails + errs
                    def passed = total - totalFailed - skips
                    
                    summary = "Tests: ${total} (Passed: ${passed}, Failed: ${totalFailed}, Skipped: ${skips})"
                    
                    // Logic for GitHub status
                    if (total > 0 && totalFailed == 0) {
                        state = "success"
                    }
                }

                updateGithubStatus(state, "CI/CD / Unit Tests", summary)
            }
        }
    }
}

def updateGithubStatus(String state, String context, String description) {
    withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
        sh """
            curl -s -H "Authorization: token ${TOKEN}" \
            -H "Content-Type: application/json" \
            -X POST \
            https://api.github.com/repos/Alphonsa-senti/todo-chart/statuses/${GIT_COMMIT} \
            -d '{
                "state": "${state}",
                "context": "${context}",
                "description": "${description}",
                "target_url": "${env.BUILD_URL}"
            }'
        """
    }
}