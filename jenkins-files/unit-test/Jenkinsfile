def BRANCH = "${env.source_branch ?: 'main'}"

pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
        // script {
        //   def branchToBuild = env.source_branch ?: 'main'
        //   checkout([
        //     $class: 'GitSCM',
        //     branches: [[name: "*/${branchToBuild}"]],
        //     userRemoteConfigs: [[
        //       url: 'https://github.com/Alphonsa-senti/todo-chart.git',
        //       credentialsId: 'basedynamics'
        //     ]]
        //   ])
        // }
      }
    }

    stage('Unit Tests') {
        steps {
            dir('.') {
                sh 'mvn test'
            }
        }
    }

    stage('Integration Tests') {
        steps {
            dir('.') {
            sh 'mvn verify -DskipUnitTests=true'
            }
        }
    }

    stage('Code Coverage') {
        steps {
            sh 'mvn clean test jacoco:report'
        }
    }
  }


  post {
    success {
      withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
        sh '''
        curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: token $TOKEN" \
        -H "Content-Type: application/json" \
        -X POST \
        https://api.github.com/repos/Alphonsa-senti/todo-chart/statuses/${GIT_COMMIT} \
        -d '{
          "state": "success",
          "context": "CI/CD",
          "description": "Build passed",
          "target_url": "'${BUILD_URL}'"
        }'
        '''
      }
    }
    failure {
      withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
        sh '''
        curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: token $TOKEN" \
        -H "Content-Type: application/json" \
        -X POST \
        https://api.github.com/repos/Alphonsa-senti/todo-chart/statuses/${GIT_COMMIT} \
        -d '{
          "state": "failure",
          "context": "CI/CD",
          "description": "Build failed",
          "target_url": "'${BUILD_URL}'"
        }'
        '''
      }
    }
  }
  
}