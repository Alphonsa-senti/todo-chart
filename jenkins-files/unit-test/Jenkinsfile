pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm

        sh 'rm -rf target'
      }
    }

    stage('Unit Tests') {
      steps {
        // Continue even on failure so we can report the summary
        sh 'mvn test -Dmaven.test.failure.ignore=true'
      }
    }

    stage('Integration Tests') {
      steps {
        sh 'mvn verify -DskipUnitTests=true -Dmaven.test.failure.ignore=true'
      }
    }

    stage('Code Coverage') {
      steps {
        sh 'mvn jacoco:report'
      }
    }
  }

