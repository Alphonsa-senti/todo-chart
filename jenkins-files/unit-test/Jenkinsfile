pipeline {
  agent any

  tools {
    maven 'Maven 3.9.11'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Unit Tests') {
        steps {
            // Use -Dmaven.test.failure.ignore=true if you want the pipeline 
            // to continue to the "Code Coverage" stage even if tests fail
            sh 'mvn test'
        }
    }

    stage('Integration Tests') {
        steps {
            sh 'mvn verify -DskipUnitTests=true'
        }
    }

    stage('Code Coverage') {
        steps {
            sh 'mvn jacoco:report'
        }
    }
  }

  post {
    always {
        // This parses the JUnit XML files so Jenkins knows the counts
        junit '**/target/surefire-reports/*.xml'
    }
    
    // We use 'always' or 'unsuccessful' to ensure the status is sent 
    // regardless of the test outcome.
    fixed { } // placeholder
    
    regression { } // placeholder

    cleanup {
      script {
        def testResult = currentBuild.rawBuild.getAction(hudson.tasks.test.AbstractTestResultAction.class)
        def summary = "No tests found"
        
        if (testResult != null) {
            def total = testResult.totalCount
            def failed = testResult.failCount
            def skipped = testResult.skipCount
            def passed = total - failed - skipped
            summary = "Tests: ${total} (✔${passed}, ✘${failed}, ↷${skipped})"
        }

        def status = currentBuild.result == 'SUCCESS' ? 'success' : 'failure'
        
        withCredentials([string(credentialsId: 'git-cred', variable: 'TOKEN')]) {
          sh """
          curl -s -H "Authorization: token $TOKEN" \
          -H "Content-Type: application/json" \
          -X POST \
          https://api.github.com/repos/Alphonsa-senti/todo-chart/statuses/${GIT_COMMIT} \
          -d '{
            "state": "${status}",
            "context": "CI/CD / Tests",
            "description": "${summary}",
            "target_url": "${BUILD_URL}"
          }'
          """
        }
      }
    }
  }
}