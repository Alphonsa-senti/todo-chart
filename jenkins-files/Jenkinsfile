def REPO = 'Alphonsa-senti/todo-chart'
def DRAFT_NAME = 'Automated Draft'
def DRAFT_PREFIX = 'v'

pipeline {
    agent any

    environment {
        GITHUB_TOKEN = credentials('github-token')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Determine Next Draft Version') {
            steps {
                script {
                    // Get the latest draft release
                    def drafts = sh(
                        script: "gh release list --repo ${REPO} --json tagName,isDraft --jq '.[] | select(.isDraft==true) | .tagName'",
                        returnStdout: true
                    ).trim()

                    if (drafts) {
                        // Extract the latest version tag (assumes semantic versioning vX.Y.Z)
                        def latestTag = drafts.split('\n')[0].split()[0]
                        echo "Latest draft tag: ${latestTag}"

                        def parts = latestTag.replace(DRAFT_PREFIX,'').tokenize('.').collect { it as int }
                        // Keep same draft if it exists (overwrite)
                        env.NEXT_TAG = "${DRAFT_PREFIX}${parts[0]}.${parts[1]}.${parts[2]}"
                    } else {
                        // No draft exists yet, start from v0.0.1
                        env.NEXT_TAG = "${DRAFT_PREFIX}0.0.1"
                    }

                    echo "Next draft tag: ${env.NEXT_TAG}"
                }
            }
        }

        stage('Create or Update Draft') {
            steps {
                script {
                    // Check if a draft with this tag exists
                    def existingDraft = sh(
                        script: "gh release view ${env.NEXT_TAG} --repo ${REPO} --json draft --jq '.draft' || echo 'false'",
                        returnStdout: true
                    ).trim()

                    if (existingDraft == "true") {
                        echo "Draft ${env.NEXT_TAG} exists, updating..."
                        sh """
                        export GITHUB_TOKEN=${GITHUB_TOKEN}
                        gh release edit ${env.NEXT_TAG} \
                            --repo ${REPO} \
                            --title "${DRAFT_NAME} ${env.NEXT_TAG}" \
                            --notes "Updated draft from Jenkins pipeline"
                        """
                        echo "Draft ${env.NEXT_TAG} updated successfully."
                    } else {
                        echo "Creating new draft ${env.NEXT_TAG}..."
                        sh """
                        export GITHUB_TOKEN=${GITHUB_TOKEN}
                        gh release create ${env.NEXT_TAG} \
                            --repo ${REPO} \
                            --draft \
                            --title "${DRAFT_NAME} ${env.NEXT_TAG}" \
                            --notes "Automated draft created from Jenkins pipeline"
                        """
                        echo "Draft ${env.NEXT_TAG} created successfully."
                    }
                }
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed!"
        }
    }
}