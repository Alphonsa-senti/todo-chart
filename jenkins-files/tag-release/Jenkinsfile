def K8S_REPO_BRANCH = 'main'
def K8S_DEPLOY_VALUE_FILE = "./charts/values.yaml"
def ENV = 'main'

pipeline {
  agent any

  stages {

    stage('Build Docker Image') {
      when {
        expression { return env.RELEASE_TAG?.trim() }
      }
      steps {
        sshagent(credentials: ['basedynamics']) {
          script {
            def now = (new Date()).format("dd-MM-yyyy-HH-mm-ss", TimeZone.getTimeZone('UTC'))
            def tag = "${ECR_REPO_URL}/${ECR_REPO_NAME}:${ENV}-${now}"
            sh """

            git checkout ${K8S_REPO_BRANCH} && git pull origin ${K8S_REPO_BRANCH} --no-rebase
            sed -i "s/^\\(\\s*tag:\\s*\\).*/\\1${ENV}-${now}/" ${K8S_DEPLOY_VALUE_FILE}
            git add ${K8S_DEPLOY_VALUE_FILE}
            git commit -m "Latest Docker Image Tag Update: ${ENV}-${now}"
            git push origin ${K8S_REPO_BRANCH}
            """
          }
        }
      }
    }

    stage('Tag Git Repo') {
      steps {
        sshagent(credentials: ['basedynamics']) {
          script {
            sh """
              
              # Check if tag already exists
              if git rev-parse "${ENV}-${now}" >/dev/null 2>&1; then
                echo "Tag ${ENV}-${now} already exists, skipping"
              else
                git tag ${ENV}-${now}
                git push origin ${ENV}-${now}
              fi
            """
          }
        }
      }
    }
  
  }
}

