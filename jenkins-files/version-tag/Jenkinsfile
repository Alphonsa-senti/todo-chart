def REPO = 'Alphonsa-senti/todo-chart'
def DRAFT_NAME = 'Automated Draft'
def DRAFT_PREFIX = 'v'

pipeline {
    agent any

    environment {
        GITHUB_TOKEN = credentials('github-token')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Determine Next Draft Version') {
            steps {
                script {
                    // Get the latest draft release
                    def drafts = sh(
                        script: "gh release list --repo ${REPO} --json tagName,isDraft --jq '.[] | select(.isDraft==true) | .tagName'",
                        returnStdout: true
                    ).trim()

                    if (drafts) {
                        // Extract the latest version tag (assumes semantic versioning vX.Y.Z)
                        env.NEXT_TAG = drafts.split('\n')[0].trim()
                        echo "Using existing draft tag: ${env.NEXT_TAG}"
                    } else {
                        def latestRelease = sh(
                            script: "gh release list --repo ${REPO} --json tagName --jq '.[0].tagName'",
                            returnStdout: true
                        ).trim()
                        if (latestRelease) {
                            def parts = latestRelease.replace(DRAFT_PREFIX,'').tokenize('.').collect { it as int }
                            parts[2] = parts[2] + 1
                            env.NEXT_TAG = "${DRAFT_PREFIX}${parts[0]}.${parts[1]}.${parts[2]}"
                        } else {
                            env.NEXT_TAG = "${DRAFT_PREFIX}0.0.1"
                        }
                        echo "No draft found, creating new tag: ${env.NEXT_TAG}"
                    }
               }
            }
        }

        stage('Generate Release Notes') {
            steps {
                script {
                    def latestPublishedTag = sh(
                        script: "gh release list --repo ${REPO} --json tagName,isDraft --jq '.[] | select(.isDraft==false) | .tagName' | head -n 1 || echo ''",
                        returnStdout: true
                    ).trim()

                    def releaseNotes = ""
                    if (latestPublishedTag) {
                        releaseNotes = sh(
                            script: "git log ${latestPublishedTag}..HEAD --pretty=format:'%h %s (%an)'",
                            returnStdout: true
                        ).trim()
                    } else {
                        // First release: include all commits
                        releaseNotes = sh(
                            script: "git log --pretty=format:'%h %s (%an)'",
                            returnStdout: true
                        ).trim()
                    }

                    env.RELEASE_NOTES = releaseNotes
                    echo "Release notes:\n${env.RELEASE_NOTES}"
                }
            }
        }
        
        stage('Create or Update Draft') {
            steps {
                script {
                    def existingDraft = sh(
                        script: "gh release view ${env.NEXT_TAG} --repo ${REPO} --json isDraft --jq '.isDraft' || echo 'false'",
                        returnStdout: true
                    ).trim()

                    if (existingDraft == "true") {
                        echo "Draft ${env.NEXT_TAG} exists, updating..."
                        sh """
                        export GITHUB_TOKEN=${GITHUB_TOKEN}
                        gh release edit ${env.NEXT_TAG} \
                            --repo ${REPO} \
                            --title "${env.NEXT_TAG}" \
                            --notes "${env.RELEASE_NOTES}"
                        """
                        echo "Draft ${env.NEXT_TAG} updated successfully."
                    } else {
                        echo "Creating new draft ${env.NEXT_TAG}..."
                        sh """
                        export GITHUB_TOKEN=${GITHUB_TOKEN}
                        gh release create ${env.NEXT_TAG} \
                            --repo ${REPO} \
                            --draft \
                            --title "${env.NEXT_TAG}" \
                            --notes "${env.RELEASE_NOTES}"
                        """
                        echo "Draft ${env.NEXT_TAG} created successfully."
                    }
                }
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed!"
        }
    }
}